{
  "name": "yummy-chat",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:db": "docker compose up -d postgres",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "npx biome format --write .",
    "check": "npm run lint && npm run typecheck",
    "check-env": "npx tsx scripts/check-env.ts",
    "db:migrate": "npm run db:migrate:test -w @yummy/db",
    "db:seed": "npm run db:seed -w @yummy/db",
    "db:reset": "npx tsx scripts/db-reset.ts",
    "smoke:auth": "npm run smoke:auth -w @yummy/be",
    "smoke:core": "npm run smoke:core -w @yummy/fe",
    "smoke:local": "npx tsx scripts/smoke-local.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3",
    "vitest": "^3.2.1"
  }
}
