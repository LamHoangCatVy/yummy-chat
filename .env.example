# Database
DATABASE_URL="postgres://postgres:postgres@localhost:5432/yummy_chat"

# Authentication (required)
BETTER_AUTH_SECRET="change-me-to-a-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# LLM Provider (optional - only needed for LLM features)
LLM_PROVIDER_API_KEY=""

# OpenAI (optional - when set, replaces the fake LLM provider)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-nano"

# Application
APP_ENV="development"
